# AI Cost Intelligence Copilot - Environment Variables Template
# Copy this file to .env and fill in actual values
# NEVER commit .env file with real secrets

# === BACKEND CONFIGURATION ===

# Server settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
ENVIRONMENT=development

# Database (PostgreSQL recommended for production)
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/cost_copilot

# === AI/LLM CONFIGURATION ===

# OpenAI API (optional, for RAG enrichment and natural language explanations)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Alternative: Anthropic Claude (future support)
# ANTHROPIC_API_KEY=sk-ant-...

# === AUTHENTICATION & SECURITY ===

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://copilot.costintelligence.ai

# === EXTERNAL INTEGRATIONS (Optional) ===

# Gmail/Email API (for cost document ingestion)
GMAIL_API_KEY=your-gmail-api-key
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ERP Systems (future)
# SAP_API_KEY=
# ORACLE_API_KEY=
# NETSUITE_API_KEY=

# Procurement Platforms (future)
# COUPA_API_KEY=
# ARIBA_API_KEY=

# Cloud Providers (for resource optimization)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AZURE_SUBSCRIPTION_ID=
# GCP_PROJECT_ID=

# === LOGGING & OBSERVABILITY ===

LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/var/log/cost-copilot/app.log

# Monitoring (optional)
# DATADOG_API_KEY=
# NEWRELIC_LICENSE_KEY=
# SENTRY_DSN=

# === FEATURE FLAGS ===

ENABLE_GRAPH_INTELLIGENCE=true
ENABLE_RAG_ENRICHMENT=true
ENABLE_APPROVAL_WORKFLOWS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SLACK_INTEGRATION=false
ENABLE_GITHUB_OAUTH=false

# === DEBUGGING (Development Only) ===

DEBUG=false
# Uncomment for verbose logging during troubleshooting:
# DEBUG=true

# === FRONTEND CONFIGURATION ===
# (if using .env.local in frontend directory)

NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# === DEVELOPMENT ONLY ===
# (remove these in production)

# Allow CORS from all origins (development only)
# CORS_ORIGINS=*

# Seed initial demo data on startup
SEED_DEMO_DATA=false

# Mock external API calls (for testing without real API keys)
MOCK_OPENAI=false
MOCK_GMAIL=false

# === NOTES ===
# 
# 1. Set DATABASE_URL for persistence (recommended for production)
# 2. Rotate SECRET_KEY before deploying to production
# 3. Never commit .env file — use .env.example as template
# 4. Use environment-specific variables for staging vs. production
# 5. Store sensitive keys in secure vaults (e.g., HashiCorp Vault, AWS Secrets Manager)
# 6. Audit .env access regularly
# 7. Rotate API keys every 90 days
#
# Remember: Secrets should be managed securely, not hardcoded!
